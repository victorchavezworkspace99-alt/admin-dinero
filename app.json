{
  "expo": {
    "name": "Balance Pro",
    "slug": "balance-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1A6DF0",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tudominio.balancepro"
    },
    "android": {
      "package": "com.tudominio.balancepro",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#1A6DF0"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "478a854b-0a3e-4ea4-bba7-f64a1b4a6f2e"
      }
    }
  }
}
