{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "cache": {
          "key": "v1",
          "paths": [
            ".npm/_cacache",
            "node_modules",
            "package-lock.json"
          ]
        }
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "channel": "production",
        "cache": {
          "key": "v1",
          "paths": [
            ".npm/_cacache",
            "node_modules",
            "package-lock.json"
          ]
        }
      }
    }
  }
}
